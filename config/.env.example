# =============================================================================
# config/.env.example — Environment Variable Configuration
#
# HOW TO USE:
#   1. Copy this file:  cp config/.env.example config/.env
#   2. Fill in your values in config/.env
#   3. NEVER commit config/.env to Git (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Slack Webhook URL
# How to get it:
#   1. Go to https://api.slack.com/apps → Create New App → From Scratch
#   2. Enable "Incoming Webhooks" → Add New Webhook to Workspace
#   3. Select your channel and copy the Webhook URL
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# -----------------------------------------------------------------------------
# Monitoring Thresholds (percentage)
# -----------------------------------------------------------------------------
CPU_THRESHOLD=80
MEM_THRESHOLD=80
DISK_THRESHOLD=85

# -----------------------------------------------------------------------------
# Log Settings
# -----------------------------------------------------------------------------
MAX_LOG_SIZE_MB=10
LOG_RETAIN_DAYS=30

# -----------------------------------------------------------------------------
# AWS S3 Settings (used by monitor.sh, archive-s3.sh, and dashboard)
# -----------------------------------------------------------------------------
S3_BUCKET=your-devops-logs-bucket-name
S3_METRICS_PREFIX=metrics          # folder where node metrics JSON files live
S3_PREFIX=p1-logs                  # folder where archived logs go
ARCHIVE_DAYS=7
AWS_REGION=ap-southeast-2          # Sydney region

# -----------------------------------------------------------------------------
# Dashboard Settings (only needed on the dashboard server)
# -----------------------------------------------------------------------------
DASHBOARD_PORT=5000
DASHBOARD_REFRESH_SECONDS=30
